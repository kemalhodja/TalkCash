# Copy to .env.render (gitignored) — used by scripts/deploy-render.ps1
# Neon: postgresql://... → script converts to postgresql+asyncpg://...?sslmode=require

DATABASE_URL=postgresql+asyncpg://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
REDIS_URL=rediss://default:TOKEN@eu1-xxx.upstash.io:6379
OPENAI_API_KEY=sk-...
