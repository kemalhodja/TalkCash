# Production (EAS / Gradle CI)
# EXPO_PUBLIC_API_URL=https://talkcash-api-prod.onrender.com/api/v1
# EXPO_PUBLIC_APP_ENV=production
# EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# Example: http://192.168.1.42:8000/api/v1
# Build APK: ../scripts/build-android-apk.sh
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_PRIVACY_URL=http://localhost:8000/privacy
EXPO_PUBLIC_TERMS_URL=http://localhost:8000/terms

# EAS project ID from https://expo.dev (run: eas init)
EAS_PROJECT_ID=

# RevenueCat (https://app.revenuecat.com → Project → API keys)
# Entitlement identifier must match RevenueCat dashboard (default: premium)
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium
