# Production (EAS build profile production sets these automatically)
# EXPO_PUBLIC_API_URL=https://talkcash-api-prod.fly.dev/api/v1
# EXPO_PUBLIC_APP_ENV=production
# EXPO_PUBLIC_PRIVACY_URL=https://talkcash-api-prod.fly.dev/privacy
# EXPO_PUBLIC_TERMS_URL=https://talkcash-api-prod.fly.dev/terms
# Example: http://192.168.1.42:8000/api/v1
# Build APK: ../scripts/build-android-apk.sh
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_PRIVACY_URL=http://localhost:8000/privacy
EXPO_PUBLIC_TERMS_URL=http://localhost:8000/terms

# EAS project ID from https://expo.dev (run: eas init)
EAS_PROJECT_ID=
