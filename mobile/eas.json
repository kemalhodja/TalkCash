{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:8000/api/v1"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://talkcash-api.fly.dev/api/v1",
        "EXPO_PUBLIC_APP_ENV": "staging",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview-local": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.237.37.46:8000/api/v1",
        "EXPO_PUBLIC_APP_ENV": "staging"
      }
    },
    "preview-prod": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://talkcash-api-prod.onrender.com/api/v1",
        "EXPO_PUBLIC_APP_ENV": "staging",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview-tunnel": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://defining-talks-interstate-fans.trycloudflare.com/api/v1",
        "EXPO_PUBLIC_APP_ENV": "staging",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "npx expo prebuild --clean",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://talkcash-api-prod.onrender.com/api/v1",
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_PRIVACY_URL": "https://talkcash-api-prod.onrender.com/privacy",
        "EXPO_PUBLIC_TERMS_URL": "https://talkcash-api-prod.onrender.com/terms",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EX_DEV_CLIENT_NETWORK_INSPECTOR": "false"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      },
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}"
      }
    }
  }
}
