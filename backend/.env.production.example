# Production / staging secrets (set via fly secrets set or hosting dashboard)

DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/talkcash
REDIS_URL=redis://default:pass@host:6379
SECRET_KEY=generate-a-long-random-string
ALLOWED_ORIGINS=https://your-frontend-domain.com
RATE_LIMIT_ENABLED=true

OPENAI_API_KEY=sk-...
SCHEDULER_ENABLED=true

# Required for production receipts (Cloudflare R2 or AWS S3)
S3_ENABLED=true
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=talkcash
S3_REGION=auto
S3_PUBLIC_URL=

# Optional OCR fallback
GOOGLE_VISION_API_KEY=
OCR_PROVIDER=auto

OVERPASS_ENABLED=true
