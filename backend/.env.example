DATABASE_URL=postgresql+asyncpg://talkcash:talkcash@db:5432/talkcash
REDIS_URL=redis://redis:6379/0
SECRET_KEY=your-secret-key-here
DEBUG=true
INTERNAL_UPGRADE_SECRET=dev-upgrade-secret
OPENAI_API_KEY=sk-your-openai-key
# Voice STT (free tier OK): https://console.groq.com/keys
GROQ_API_KEY=gsk-your-groq-key
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# Dahili test: tüm kullanıcılara Pro özellikleri (üretimde false yapın)
BILLING_PREMIUM_UNLOCKED=false
# Required for voice (Groq or OpenAI). LLM mentor/podcast needs OPENAI_API_KEY.
# Local text parser works without any key (Turkish/English regex).
# Docker: copy to backend/.env or export before `docker compose up`.

# Apple App Store (StoreKit)
APPLE_VERIFY_MOCK=true
APPLE_SHARED_SECRET=
GOOGLE_PLAY_PACKAGE_NAME=io.talkcash.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_RTDN_WEBHOOK_SECRET=

# Password reset email (Resend: smtp.resend.com, port 587, user resend, password = API key)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@talkcash.io
SMTP_USE_TLS=true
PASSWORD_RESET_URL=talkcash://reset-password

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# S3 / MinIO (local dev — production requires S3_ENABLED=true + credentials)
S3_ENABLED=false
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=talkcash
S3_SECRET_KEY=talkcash123
S3_BUCKET=talkcash
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/talkcash
