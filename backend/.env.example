DATABASE_URL=postgresql+asyncpg://talkcash:talkcash@db:5432/talkcash
REDIS_URL=redis://redis:6379/0
SECRET_KEY=your-secret-key-here
DEBUG=true
INTERNAL_UPGRADE_SECRET=dev-upgrade-secret
OPENAI_API_KEY=sk-your-openai-key
# Required for voice + LLM NLP. Local fallback works without it (Turkish/English regex parser).
# Docker: copy to backend/.env or export before `docker compose up`.

# Google Play Billing
GOOGLE_PLAY_VERIFY_MOCK=true
GOOGLE_PLAY_PACKAGE_NAME=io.talkcash.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_RTDN_WEBHOOK_SECRET=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# SMTP (password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@talkcash.io
SMTP_USE_TLS=true

# S3 / MinIO (opsiyonel — false ise yerel dosya sistemi)
S3_ENABLED=false
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=talkcash
S3_SECRET_KEY=talkcash123
S3_BUCKET=talkcash
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/talkcash
